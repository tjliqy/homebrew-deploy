			"ENG_name": "Random Clues; Murder Evidence",
			"name": "随机线索；谋杀证据",
			"source": "GiddyTable",
			"caption": "谋杀证据",
			"colLabels": [
				"1d6",
				"证据"
			],
			"colStyles": [
				"col-2 text-center",
				"col-10"
			],
			"intro": [
				"当需要快速获取谋杀现场证据碎片时，以下表格可用作激励。",
				"{@note \"介绍\"部分是可选的。}"
			],
			"rows": [
				[
					"1",
					"属于嫌疑人的一件被丢弃或遗忘的衣物碎片"
				],
				[
					"2",
					"一把沾满鲜血的武器"
				],
				[
					"3",
					"使用特定法术进行魔法攻击的可识别标记"
				],
				[
					"4",
					"包含一个或多个嫌疑人定罪消息的信件"
				],
				[
					"5",
					"一条鲜血痕迹通向该组织一名昏迷且重伤的成员"
				],
				[
					"6",
					"一个活体证人，他无法或不愿意离开犯罪现场"
				]
			],
			"outro": [
				"理想情况下，应在需要此表格的情景发生前查阅该表格，因为结果可以融入更大的剧情线索中。",
				"{@note \"结尾\"部分是可选的。}"
			]
		}
	]
