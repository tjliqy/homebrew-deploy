		{
			"ENG_name": "Ancient Enmity",
			"name": "远古敌意",
			"source": "GiddyOptionalfeature",
			"featureType": [
				"MM:D"
			],
			"prerequisite": [
				{
					"feature": [
						"龙族血脉子职"
					]
				}
			],
			"entries": [
				"当你施放一个影响一个或多个巨人类型生物的法术时，你可以消耗1个术法点来为法术造成的任何伤害骰添加一个额外的d6。"
			]
		},
		{
			"ENG_name": "Mark of Pain",
			"name": "苦痛标记",
			"source": "GiddyOptionalfeature",
			"featureType": [
				"EI"
			],
			"prerequisite": [
				{
					"level": {
						"level": 5,
						"class": {
							"ENG_name": "Warlock",
							"name": "魔契师"
						}
					}
				}
			],
			"entries": [
				"当你以一次攻击命中一个生物时，你可以选择标记该生物。该生物被你标记直到你的下一个回合开始。每当你受到伤害时，每个被你标记的生物受到等同于你所受伤害的黯蚀伤害。"
			]
		}
	]
