				}
			],
			"instructions": [
				"将馅料烤熟，然后在两面涂抹黄油。",
				"将馅料夹在面包之间。根据口味加入盐和胡椒。",
				"盛于板甲上，或立即食用。"
			],
			"fluff": {
				"entries": [
					"吐司三明治是一种用两片面包制成的三明治，其中夹心是一片薄薄的烤面包片，可以大量涂上黄油。一份1861年的食谱说要按口味添加盐和胡椒。"
				]
			}
		}
